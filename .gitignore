# Ignore exported CSV files and parquet files
*.csv
*.parquet
# Ignore temporary files
*.tmp
*.log

# Ignore database configuration files
*.db
*.sql

# Ignore all files in a specific directory
/src/
/temp/
/data/
/test/

# Ignore OS-generated files
.DS_Store
Thumbs.db
desktop.ini

# Ignore Python virtual environments
venv/
.env
mdc_analytics_env/

# Ignore IDE or editor settings
.vscode/
.idea/

# Ignore compiled code
*.class
*.pyc
*.o
*.out

# Ignore sensitive credential files (if any)
config.yaml
config.json
credentials.txt

# Add these new entries:
# Jupyter Notebook
.ipynb_checkpoints/
*.ipynb_checkpoints/

# Python cache
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
dist/
build/
*.egg-info/

# ML specific
*.h5
*.pkl
*.model
*.joblib

# Environment
.python-version
.env.local
.env.*.local

# Logs and databases
*.log
*.sqlite
*.db-journal

# Coverage reports
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

